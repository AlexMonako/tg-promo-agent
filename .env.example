# === Required ===
# Get from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Generate once locally with `python -m tg_promo_agent.scripts.login`
TELEGRAM_SESSION_STRING=

# LLM for decision-making
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# === Optional ===
# TGStat API (https://api.tgstat.ru/docs) — required for analytics + similar-channel discovery
TGSTAT_TOKEN=

# How often the agent wakes up to decide next action (seconds)
AGENT_TICK_SECONDS=600

# Dry-run mode: agent decides but doesn't actually post / DM / comment
DRY_RUN=true

# Path to config file listing your own channels + policy
CONFIG_PATH=config.yaml

# SQLite state file (absolute path on Railway volume recommended)
STATE_DB_PATH=data/state.sqlite3

# Health endpoint port (Railway injects $PORT)
PORT=8080

# Cross-posting targets (all optional — leave blank to skip)
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
VK_ACCESS_TOKEN=
